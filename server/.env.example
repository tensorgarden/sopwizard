# Model-backed narration (optional; deterministic narration otherwise).
# A local Ollama is detected automatically; for a hosted endpoint set:
# LLM_URL=
# LLM_MODEL=
# LLM_API_KEY=

# Cloud sync (optional): mirrors SOP metadata, usage, and errors to the team
# workspace. Sign in as a workspace account that belongs to an organization.
# Counters and titles only — never step text, guidance, or screenshots.
# SYNC_URL=
# SYNC_ANON_KEY=
# SYNC_EMAIL=
# SYNC_PASSWORD=

# Shared corpus (optional, OFF by default). When on, the review deltas from an
# approved SOP — what the narrator wrote and what a person corrected it to —
# are contributed to a store that OTHER organizations can read once the same
# label has been seen at CORPUS_K distinct organizations (k-anonymity). This is
# a cross-organization data flow: turn it on only for tenants who have
# consented to it. Requires sync to be configured above.
# CORPUS=on
# CORPUS_K=5

# Approval webhook (optional): when a SOP is approved, POST a metadata-only
# signal ("a fresh, reviewed SOP is ready to ingest") to this endpoint. Never
# includes the SOP body — only its title, id, and where to fetch it.
# WEBHOOK_URL=
